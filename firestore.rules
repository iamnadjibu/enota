rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isMaster() {
      return isAuthenticated() && request.auth.token.email == "nadjibullahu@gmail.com";
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && (
        isMaster() || (
          getUserData().role == "admin" &&
          getUserData().status == "active"
        )
      );
    }

    function isFacultyAdmin(faculty) {
      return isMaster() || (
        isAdmin() && getUserData().faculty == faculty
      );
    }

    // --- COLLECTIONS ---

    // Users Collection
    match /users/{userId} {
      // Admins can see all users, users can see themselves
      allow read: if isAuthenticated() && (isAdmin() || request.auth.uid == userId);
      // Anyone can register
      allow create: if true; 
      // Users can update their own profile (excluding sensitive fields), Master can update anyone
      allow update: if isMaster() || (
        request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status', 'faculty', 'institution', 'regNumber'])
      );
      // Only Master can delete users
      allow delete: if isMaster();
    }

    // Marks Collection (Public Access for Searching)
    match /marks/{markId} {
      // Requirement: Users can search for marks without logging in
      allow read: if true; 
      
      // Writes restricted to Master or Faculty Admins
      allow create: if isMaster() || isFacultyAdmin(request.resource.data.faculty);
      allow update: if isMaster() || isFacultyAdmin(resource.data.faculty);
      allow delete: if isMaster();
    }

    // Courses/Materials Collection
    match /courses/{courseId} {
      // Requirement: Access materials in their faculty that they have signed up in
      // Admins can see all courses
      // Students must be logged in and the course must belong to their faculty
      allow read: if isAdmin() || (
        isAuthenticated() && 
        resource.data.faculties.hasAny([getUserData().faculty])
      );
      
      // Writes restricted to Master or Faculty Admins
      allow create: if isMaster() || isFacultyAdmin(request.resource.data.faculty);
      allow update: if isMaster() || isFacultyAdmin(resource.data.faculty);
      allow delete: if isMaster() || isFacultyAdmin(resource.data.faculty);
    }

    // Settings/Branding
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isMaster();
    }

    // Site Configurations
    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isMaster();
    }
    
    // Metadata Collections
    match /faculties/{facultyId} {
      allow read: if true;
      allow write: if isMaster();
    }

    match /institutions/{instId} {
      allow read: if true;
      allow write: if isMaster();
    }
  }
}


